      d.setDate(start.getDate() + i);
      dateRange.push(d.toISOString().split('T')[0]);
    }

    await new Promise(resolve => setTimeout(resolve, 1500));

    const apiKey = "";
    const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`;

    const promptText = `
      คุณคือผู้เชี่ยวชาญด้านทรัพยากรบุคคลและระบบ AI อัจฉริยะในการจัดตารางเวรโรงพยาบาลและห้องปฏิบัติการ
      จงจัดตารางเวรให้กับพนักงานจากข้อมูลต่อไปนี้ให้เหมาะสมที่สุด:

      รายชื่อพนักงาน:
      ${JSON.stringify(employees, null, 2)}

      ประวัติวันลาของพนักงาน (ห้ามลงเวรเด็ดขาด ยกเว้นกรณีครึ่งวัน):
      ${JSON.stringify(leaves, null, 2)}

      ประเภทเวรที่มีอยู่ในระบบในปัจจุบัน (ต้องจัดเวรตามรายการกะและโควตาความต้องการด้านล่างนี้เท่านั้น):
      ${JSON.stringify(shiftTypes, null, 2)}
      * ข้อสังเกตสำคัญในโควตาการจัดสรรงานของพนักงาน (requiredStaff):
        - หาก requiredStaff เท่ากับ "everyone_else" หมายความว่ากะเวรนั้นจะต้องจัดพนักงาน "ทุกคนที่เหลือปฏิบัติงาน" ที่ยังไม่ได้ลงทะเบียนกะอื่น และไม่มีการแจ้งลางานในวันดังกล่าว
        - หาก requiredStaff เป็นตัวเลข (เช่น 1, 2) หมายความว่าคุณต้องพยายามจัดสรรคนทำงานให้ครบจำนวนตัวเลขเป้าหมายนั้น ๆ พอดีในแต่ละกะ

      ช่วงวันที่ต้องการจัดเวร (${aiDaysCount} วัน):
      ${JSON.stringify(dateRange)}

      กฎเหล็กที่คุณต้องทำตามอย่างเคร่งครัด:
      1. ห้ามให้พนักงานลงเวรในวันที่ลางานเต็มวันเด็ดขาด (เช่น VACATION, SICK, PERSONAL_FULL, MATERNITY)
      2. กฎการลากิจครึ่งวัน (สำคัญมาก):
         - หากพนักงานลา "PERSONAL_MORNING" (ลากิจครึ่งเช้า 8.00-12.00) สามารถจัดเวรกะที่เริ่มตอนเช้า (เช่น morning, chob, chobdor, smc, blood) ในวันนั้นให้เขาได้ (โดยพนักงานจะทำงานเฉพาะครึ่งบ่าย 12.00-16.00)
         - หากพนักงานลา "PERSONAL_AFTERNOON" (ลากิจครึ่งบ่าย 12.00-16.00) สามารถจัดเวรกะที่เริ่มตอนเช้า (เช่น morning, chob, chobdor, smc, blood) ในวันนั้นให้เขาได้ (โดยพนักงานจะทำงานเฉพาะครึ่งเช้า 8.00-12.00)
      3. พนักงานที่กำลังตั้งครรภ์ (isPregnant === true) ห้ามได้กะดึกข้ามวัน (กะที่มี ID = "chobdor" หรือเวร 24 ชั่วโมง หรือเวรที่มีคำว่า "ชบด") โดยเด็ดขาดเพื่อความปลอดภัย
      4. พนักงาน 1 คน มีเวรได้สูงสุดเพียง 1 เวรต่อวันเท่านั้น
      5. สำหรับกะเวรเช้า (morning) หรือกะเวรที่มี requiredStaff เท่ากับ "everyone_else" ให้ตรวจและกวาดพนักงานที่เหลือทุกคนในวันนั้นลงเวรนี้ทั้งหมด
      6. กระจายจำนวนเวรอื่น ๆ ให้เท่าเทียมและเหมาะสมที่สุดในหมู่พนักงานทุกคนตามความสามารถ

      จงตอบกลับเฉพาะข้อมูล JSON เท่านั้น ห้ามเขียนอธิบายใดๆ ทั้งสิ้น โดยใช้โครงสร้าง Schema ดังนี้:
      {
        "shifts": [
          { "userId": "รหัสพนักงาน", "date": "YYYY-MM-DD", "type": "ไอดีประเภทเวรที่ต้องการจัดให้" }
        ]
      }
    `;

    const fetchAiData = async (retries = 3, delay = 1000) => {
      try {
        const response = await fetch(url, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            contents: [{ parts: [{ text: promptText }] }],
            generationConfig: { 
              responseMimeType: "application/json",
              responseSchema: {
                type: "OBJECT",
                properties: {
                  shifts: {
                    type: "ARRAY",
                    items: {
                      type: "OBJECT",
                      properties: {
                        userId: { type: "STRING" },
                        date: { type: "STRING" },
                        type: { type: "STRING" }
                      },
                      required: ["userId", "date", "type"]
                    }
                  }
                },
                required: ["shifts"]
              }
            }
          })
        });

        if (!response.ok) throw new Error("API call failed");
        const resData = await response.json();
        const jsonText = resData.candidates?.[0]?.content?.parts?.[0]?.text;
        return JSON.parse(jsonText);
      } catch (err) {
        if (retries > 0) {
          await new Promise(res => setTimeout(res, delay));
          return fetchAiData(retries - 1, delay * 2);
        }
        throw err;
      }
    };

    try {
      const aiResponse = await fetchAiData();
      if (aiResponse && aiResponse.shifts && aiResponse.shifts.length > 0) {
        const finalShifts = aiResponse.shifts.map(s => ({
          id: `s_ai_${Date.now()}_${s.date}_${s.type}_${Math.random().toString(36).substr(2, 5)}`,
          userId: s.userId,
          date: s.date,
          type: s.type
        }));

        const filteredOriginalShifts = shifts.filter(s => !dateRange.includes(s.date));
        setShifts([...filteredOriginalShifts, ...finalShifts]);
        triggerToast('AI อัจฉริยะได้คำนวณและเกลี่ยจำนวนพนักงานให้ครบถ้วนตามความต้องการสำเร็จแล้ว!', 'success');
      } else {
        throw new Error("Invalid AI output format");
      }
    } catch (error) {
      console.log("Switching to Local Heuristic Scheduler...");
