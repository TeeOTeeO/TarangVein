      setNewShiftType({ label: '', textSymbol: '🌅', themeIdx: 0, requiredStaff: '1' });
    }
    setShifts(shifts.filter(s => s.type !== id));
    setShiftTypes(shiftTypes.filter(st => st.id !== id));
    triggerToast('ลบประเภทเวรเรียบร้อยแล้ว', 'error');
  };

  // --- ฟังก์ชันจัดเวรพนักงาน ---
  const handleAddShift = (e) => {
    e.preventDefault();
    const selectedUser = getUserById(newShift.userId);
    if (!selectedUser) {
      triggerToast('กรุณาเลือกพนักงานก่อนจัดเวร', 'error');
      return;
    }

    const onLeave = getApprovedLeaveOnDate(newShift.userId, newShift.date);
    if (onLeave) {
      const isHalfDayLeave = onLeave.type === 'PERSONAL_MORNING' || onLeave.type === 'PERSONAL_AFTERNOON';
      if (isHalfDayLeave && (newShift.type === 'morning' || newShift.type === 'chob' || newShift.type === 'chobdor' || newShift.type === 'smc' || newShift.type === 'blood')) {
        // ผ่าน
      } else {
