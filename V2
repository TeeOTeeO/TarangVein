    },
    { 
      id: 'l2', 
      userId: '4', 
      startDate: new Date(Date.now() + 86400000 * 5).toISOString().split('T')[0], 
      endDate: new Date(Date.now() + 86400000 * 5).toISOString().split('T')[0], 
      type: 'VACATION', 
      reason: 'ไปพักผ่อนต่างจังหวัดรอบที่ 2',
      status: 'approved' 
    },
    { 
      id: 'l3', 
