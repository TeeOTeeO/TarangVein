    }
  ]);

  // ระบบแจ้งเตือน (Custom Toast Notification)
  const [toast, setToast] = useState({ show: false, message: '', type: 'success' });

  // ฟอร์มสำหรับเพิ่มพนักงานใหม่
  const [newEmployee, setNewEmployee] = useState({
    prefix: 'นาย',
    name: '',
    position: 'MT',
    age: '',
    isPregnant: false
  });

  // ฟอร์มสำหรับจัดเวร
  const [newShift, setNewShift] = useState({
    userId: '2', 
    date: new Date().toISOString().split('T')[0],
    type: 'morning'
  });

  // ฟอร์มสำหรับพนักงานยื่นใบลา
  const [newLeave, setNewLeave] = useState({
    userId: '2',
    startDate: new Date().toISOString().split('T')[0],
    endDate: new Date().toISOString().split('T')[0],
    type: 'PERSONAL_MORNING',
    reason: ''
  });

  // --- States สำหรับการจัดตารางด้วย AI ---
  const [isAiLoading, setIsAiLoading] = useState(false);
  const [aiDaysCount, setAiDaysCount] = useState(7); // จัดล่วงหน้ากี่วัน
  const [aiStartDate, setAiStartDate] = useState(new Date().toISOString().split('T')[0]);

  // --- ฟังก์ชันแสดงข้อความแจ้งเตือน ---
  const triggerToast = (message, type = 'success') => {
    setToast({ show: true, message, type });
    setTimeout(() => {
      setToast({ show: false, message: '', type: 'success' });
    }, 3000);
  };

  // --- ฟังก์ชันจัดฟอร์แมตวันที่ให้อ่านง่าย ---
  const formatDate = (dateString) => {
    if (!dateString) return "";
    const options = { weekday: 'short', day: 'numeric', month: 'short' };
    return new Date(dateString).toLocaleDateString('th-TH', options);
  };

  // --- คำนวณวันในเดือนสำหรับสร้างปฏิทินรายเดือน ---
  const calendarDays = useMemo(() => {
    const firstDayIndex = new Date(currentYear, currentMonth, 1).getDay();
    const totalDays = new Date(currentYear, currentMonth + 1, 0).getDate();
    const prevTotalDays = new Date(currentYear, currentMonth, 0).getDate();

    const days = [];

    for (let i = firstDayIndex - 1; i >= 0; i--) {
      const dayNum = prevTotalDays - i;
      const prevMonth = currentMonth === 0 ? 11 : currentMonth - 1;
      const prevYear = currentMonth === 0 ? currentYear - 1 : currentYear;
      const dateString = `${prevYear}-${String(prevMonth + 1).padStart(2, '0')}-${String(dayNum).padStart(2, '0')}`;
      days.push({
        dateString,
        dayNum,
        isCurrentMonth: false,
      });
    }

    for (let i = 1; i <= totalDays; i++) {
      const dateString = `${currentYear}-${String(currentMonth + 1).padStart(2, '0')}-${String(i).padStart(2, '0')}`;
      days.push({
        dateString,
        dayNum: i,
        isCurrentMonth: true,
      });
    }

    const remainingSlots = 42 - days.length;
    for (let i = 1; i <= remainingSlots; i++) {
      const nextMonth = currentMonth === 11 ? 0 : currentMonth + 1;
      const nextYear = currentMonth === 11 ? currentYear + 1 : currentYear;
      const dateString = `${nextYear}-${String(nextMonth + 1).padStart(2, '0')}-${String(i).padStart(2, '0')}`;
      days.push({
        dateString,
        dayNum: i,
        isCurrentMonth: false,
      });
    }

    return days;
  }, [currentMonth, currentYear]);

  const handlePrevMonth = () => {
    if (currentMonth === 0) {
      setCurrentMonth(11);
      setCurrentYear(currentYear - 1);
    } else {
      setCurrentMonth(currentMonth - 1);
    }
  };

  const handleNextMonth = () => {
    if (currentMonth === 11) {
      setCurrentMonth(0);
      setCurrentYear(currentYear + 1);
    } else {
      setCurrentMonth(currentMonth + 1);
    }
  };

  const getUserById = (id) => employees.find(u => u.id === id);

  // ตรวจสอบว่าพนักงานลางานในวันที่กำหนดหรือไม่
  const getApprovedLeaveOnDate = (userId, dateStr) => {
    const targetDate = new Date(dateStr);
    targetDate.setHours(0,0,0,0);

    return leaves.find(l => {
      if (l.userId !== userId || l.status !== 'approved') return false;
      const start = new Date(l.startDate);
      const end = new Date(l.endDate);
      start.setHours(0,0,0,0);
      end.setHours(0,0,0,0);
      return targetDate >= start && targetDate <= end;
    });
  };

  // --- ฟังก์ชันจัดการข้อมูล (Actions) ---
  
  // เพิ่มพนักงานใหม่
  const handleAddEmployee = (e) => {
    e.preventDefault();
    if (!newEmployee.name.trim() || !newEmployee.age) {
      triggerToast('กรุณากรอกข้อมูลพนักงานให้ครบถ้วน', 'error');
      return;
    }

    const canBePregnant = newEmployee.prefix === 'นาง' || newEmployee.prefix === 'นางสาว';

    const createdEmployee = {
      id: `emp_${Date.now()}`,
      prefix: newEmployee.prefix,
      name: newEmployee.name,
      position: newEmployee.position,
      age: parseInt(newEmployee.age),
      isPregnant: canBePregnant ? newEmployee.isPregnant : false
    };

    setEmployees([...employees, createdEmployee]);
    setNewEmployee({ prefix: 'นาย', name: '', position: 'MT', age: '', isPregnant: false });
    triggerToast('เพิ่มข้อมูลพนักงานเรียบร้อยแล้ว');
  };

  // ลบพนักงาน
  const handleDeleteEmployee = (id) => {
    setShifts(shifts.filter(s => s.userId !== id));
    setLeaves(leaves.filter(l => l.userId !== id));
    setEmployees(employees.filter(e => e.id !== id));
    triggerToast('ลบข้อมูลพนักงานเรียบร้อยแล้ว', 'error');
  };

  // เพิ่มเวร
  const handleAddShift = (e) => {
    e.preventDefault();
    const selectedUser = getUserById(newShift.userId);
    if (!selectedUser) {
      triggerToast('กรุณาเลือกพนักงานก่อนจัดเวร', 'error');
      return;
    }

    const onLeave = getApprovedLeaveOnDate(newShift.userId, newShift.date);
    if (onLeave) {
      const isHalfDayLeave = onLeave.type === 'PERSONAL_MORNING' || onLeave.type === 'PERSONAL_AFTERNOON';
      if (isHalfDayLeave && newShift.type === 'morning') {
        // ให้ผ่านเงื่อนไขไปบันทึกได้เลย
      } else {
        const leaveInfo = LEAVE_TYPES[onLeave.type] || { label: 'ลางาน' };
        triggerToast(`ไม่สามารถจัดเวรได้เนื่องจากพนักงานลงทะเบียนลางานเต็มวันในวันดังกล่าว (${leaveInfo.label})`, 'error');
        return;
      }
    }

    const isDuplicate = shifts.some(s => s.userId === newShift.userId && s.date === newShift.date && s.type === newShift.type);
    if (isDuplicate) {
      triggerToast('พนักงานท่านนี้ลงกะเวรดังกล่าวในวันนี้ไปแล้ว', 'error');
      return;
    }

    const newShiftData = {
      id: `s_${Date.now()}`,
      ...newShift
    };
    setShifts([...shifts, newShiftData]);
    triggerToast('จัดตารางเวรให้พนักงานสำเร็จแล้ว');
  };

  // บันทึกการลาโดยตรง
  const handleAddLeaveRequest = (e) => {
    e.preventDefault();
    if (new Date(newLeave.startDate) > new Date(newLeave.endDate)) {
      triggerToast('วันที่เริ่มต้นลา ต้องไม่มากกว่าวันที่สิ้นสุดลา', 'error');
      return;
    }

    const newRequest = {
      id: `leave_${Date.now()}`,
      ...newLeave,
      status: 'approved'
    };

    setLeaves([...leaves, newRequest]);
    setNewLeave({
      userId: employees[0]?.id || '',
      startDate: new Date().toISOString().split('T')[0],
      endDate: new Date().toISOString().split('T')[0],
      type: 'PERSONAL_MORNING',
      reason: ''
    });
    triggerToast('บันทึกประวัติการลาเรียบร้อยแล้ว');
  };

  // ลบประวัติการลา
  const handleDeleteLeave = (leaveId) => {
    setLeaves(leaves.filter(l => l.id !== leaveId));
    triggerToast('ลบประวัติการลาเรียบร้อยแล้ว', 'error');
  };

  // ลบกะเวรรายวัน
  const handleDeleteShift = (shiftId) => {
    setShifts(shifts.filter(s => s.id !== shiftId));
    triggerToast('ลบตารางเวรเรียบร้อยแล้ว');
  };

  // --- ระบบ AI ช่วยจัดตารางเวรอัตโนมัติ ---
  const runLocalSmartScheduler = (startDateStr, daysCount) => {
    const generatedShifts = [];
    const shiftTracking = {};
    employees.forEach(emp => {
      shiftTracking[emp.id] = 0;
    });

    const start = new Date(startDateStr);
    
    for (let i = 0; i < daysCount; i++) {
      const targetDate = new Date(start);
      targetDate.setDate(start.getDate() + i);
      const dateString = targetDate.toISOString().split('T')[0];

      const shiftTypesOrder = ['morning', 'afternoon', 'night'];
      const assignedToday = new Set();

      shiftTypesOrder.forEach(shiftType => {
        const eligibleEmployees = employees.filter(emp => {
          const leave = getApprovedLeaveOnDate(emp.id, dateString);
          if (leave) {
            if (leave.type !== 'PERSONAL_MORNING' && leave.type !== 'PERSONAL_AFTERNOON') {
              return false;
            }
            if (shiftType !== 'morning') {
              return false;
            }
          }

          if (assignedToday.has(emp.id)) return false;
          if (shiftType === 'night' && emp.isPregnant) return false;

          return true;
        });

        if (eligibleEmployees.length > 0) {
          eligibleEmployees.sort((a, b) => shiftTracking[a.id] - shiftTracking[b.id]);
          const selectedEmp = eligibleEmployees[0];

          generatedShifts.push({
            id: `s_ai_${Date.now()}_${dateString}_${shiftType}`,
            userId: selectedEmp.id,
            date: dateString,
            type: shiftType
          });

          assignedToday.add(selectedEmp.id);
          shiftTracking[selectedEmp.id] += 1;
        }
      });
    }

    return generatedShifts;
  };

  const handleAiAutoSchedule = async () => {
    if (employees.length === 0) {
      triggerToast('กรุณาเพิ่มพนักงานในระบบก่อนใช้ AI', 'error');
      return;
    }

    setIsAiLoading(true);
    triggerToast('AI กำลังเริ่มประมวลผลตารางเวร...', 'success');

    const start = new Date(aiStartDate);
    const dateRange = [];
    for (let i = 0; i < aiDaysCount; i++) {
      const d = new Date(start);
      d.setDate(start.getDate() + i);
      dateRange.push(d.toISOString().split('T')[0]);
    }

    await new Promise(resolve => setTimeout(resolve, 1500));

    const apiKey = "";
    const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`;

    const promptText = `
      คุณคือผู้เชี่ยวชาญด้านทรัพยากรบุคคลและระบบ AI อัจฉริยะในการจัดตารางเวรโรงพยาบาลและห้องปฏิบัติการ
      จงจัดตารางเวรให้กับพนักงานจากข้อมูลต่อไปนี้ให้เหมาะสมที่สุด:

      รายชื่อพนักงาน:
      ${JSON.stringify(employees, null, 2)}

      ประวัติวันลาของพนักงาน (ห้ามลงเวรเด็ดขาด ยกเว้นกรณีครึ่งวัน):
      ${JSON.stringify(leaves, null, 2)}

      ช่วงวันที่ต้องการจัดเวร (${aiDaysCount} วัน):
      ${JSON.stringify(dateRange)}

      กฎเหล็กที่คุณต้องทำตามอย่างเคร่งครัด:
      1. ห้ามให้พนักงานลงเวรในวันที่ลางานเต็มวันเด็ดขาด (เช่น VACATION, SICK, PERSONAL_FULL, MATERNITY)
      2. กฎการลากิจครึ่งวัน (สำคัญมาก):
         - หากพนักงานลา "PERSONAL_MORNING" (ลากิจครึ่งเช้า 8.00-12.00) สามารถจัดเวรกะเช้า ("morning") ในวันนั้นให้เขาได้ (โดยพนักงานจะทำงานเฉพาะครึ่งบ่าย 12.00-16.00) แต่ห้ามจัดกะ afternoon หรือ night เด็ดขาด
         - หากพนักงานลา "PERSONAL_AFTERNOON" (ลากิจครึ่งบ่าย 12.00-16.00) สามารถจัดเวรกะเช้า ("morning") ในวันนั้นให้เขาได้ (โดยพนักงานจะทำงานเฉพาะครึ่งเช้า 8.00-12.00) แต่ห้ามจัดกะ afternoon หรือ night เด็ดขาด
      3. พนักงานที่กำลังตั้งครรภ์ (isPregnant === true) ห้ามได้กะดึก (night) โดยเด็ดขาดเพื่อความปลอดภัยทางสรีรวิทยา
      4. พนักงาน 1 คน มีเวรได้สูงสุดเพียง 1 เวรต่อวันเท่านั้น
      5. กระจายจำนวนเวรให้เท่าเทียมและเหมาะสมที่สุดในหมู่พนักงานทุกคนตามความสามารถ
      6. ในหนึ่งวันควรมีเวร 3 ประเภทครบถ้วนคือ: morning (เช้า), afternoon (บ่าย), และ night (ดึก) (หากพนักงานพร้อม)

      จงตอบกลับเฉพาะข้อมูล JSON เท่านั้น ห้ามเขียนอธิบายใดๆ ทั้งสิ้น โดยใช้โครงสร้าง Schema ดังนี้:
      {
        "shifts": [
          { "userId": "รหัสพนักงาน", "date": "YYYY-MM-DD", "type": "morning หรือ afternoon หรือ night" }
        ]
      }
    `;

    const fetchAiData = async (retries = 3, delay = 1000) => {
      try {
        const response = await fetch(url, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            contents: [{ parts: [{ text: promptText }] }],
            generationConfig: { 
              responseMimeType: "application/json",
              responseSchema: {
                type: "OBJECT",
                properties: {
                  shifts: {
                    type: "ARRAY",
                    items: {
                      type: "OBJECT",
                      properties: {
                        userId: { type: "STRING" },
                        date: { type: "STRING" },
                        type: { type: "STRING" }
                      },
                      required: ["userId", "date", "type"]
                    }
                  }
                },
                required: ["shifts"]
              }
            }
          })
        });

        if (!response.ok) throw new Error("API call failed");
        const resData = await response.json();
        const jsonText = resData.candidates?.[0]?.content?.parts?.[0]?.text;
        return JSON.parse(jsonText);
      } catch (err) {
        if (retries > 0) {
          await new Promise(res => setTimeout(res, delay));
          return fetchAiData(retries - 1, delay * 2);
        }
        throw err;
      }
    };

    try {
      const aiResponse = await fetchAiData();
      if (aiResponse && aiResponse.shifts && aiResponse.shifts.length > 0) {
        const finalShifts = aiResponse.shifts.map(s => ({
          id: `s_ai_${Date.now()}_${s.date}_${s.type}_${Math.random().toString(36).substr(2, 5)}`,
          userId: s.userId,
          date: s.date,
          type: s.type
        }));

        const filteredOriginalShifts = shifts.filter(s => !dateRange.includes(s.date));
        setShifts([...filteredOriginalShifts, ...finalShifts]);
        triggerToast('AI อัจฉริยะได้คำนวณและประมวลผลตารางเวรให้คุณสำเร็จแล้ว!', 'success');
      } else {
        throw new Error("Invalid AI output format");
