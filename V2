      groups[leave.userId].stats[leaveTypeLabel] = (groups[leave.userId].stats[leaveTypeLabel] || 0) + 1;
    });

    Object.values(groups).forEach(group => {
      group.items.sort((a, b) => new Date(b.startDate) - new Date(a.startDate));
