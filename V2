  // ระบบเก็บข้อมูลการลาพักร้อน/ลางาน
  const [leaves, setLeaves] = useState([
    { 
      id: 'l1', 
      userId: '4', 
      startDate: new Date().toISOString().split('T')[0], 
      endDate: new Date().toISOString().split('T')[0], 
      type: 'VACATION', 
