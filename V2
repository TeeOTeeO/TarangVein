  // บันทึกการลาโดยตรง
  const handleAddLeaveRequest = (e) => {
    e.preventDefault();
    if (new Date(newLeave.startDate) > new Date(newLeave.endDate)) {
      triggerToast('วันที่เริ่มต้นลา ต้องไม่มากกว่าวันที่สิ้นสุดลา', 'error');
