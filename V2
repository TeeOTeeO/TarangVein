                                ครั้งที่ {items.length - index}: {leaveInfo.label}
                              </span>
                              
                              <button
                                onClick={() => handleDeleteLeave(leave.id)}
                                className="absolute top-2.5 right-2 text-gray-400 hover:text-red-600 transition-colors p-1"
                                title="ลบวันลารายการนี้"
                              >
                                <Trash2 className="w-3.5 h-3.5" />
                              </button>
                            </div>

                            <div className="text-gray-700 font-medium pt-0.5">
                              📆 {startDateObj.toLocaleDateString('th-TH', { day: 'numeric', month: 'short', year: 'numeric' })}
                              {leave.startDate !== leave.endDate && ` ถึง ${endDateObj.toLocaleDateString('th-TH', { day: 'numeric', month: 'short', year: 'numeric' })}`}
                            </div>

                            {leave.reason ? (
                              <p className="text-[11px] text-gray-500 italic bg-white p-1.5 rounded border border-gray-100">
                                <span className="font-semibold text-gray-700 not-italic">เหตุผล:</span> "{leave.reason}"
                              </p>
                            ) : (
                              <span className="text-[10px] text-gray-400 italic font-sans">ไม่ได้ระบุเหตุผลการลา</span>
                            )}
                          </div>
                        );
                      })}
                    </div>
                  </div>
                );
              })}
            </div>
          )}
        </div>
      </div>
    );
  };

  // --- Main Render ---
  return (
    <div className="min-h-screen bg-slate-50 font-sans text-gray-900 font-sans">
      {/* Custom Alert/Toast Notification */}
      {toast.show && (
        <div className={`fixed top-5 right-5 z-50 flex items-center gap-2 px-4 py-3 rounded-xl shadow-lg border text-sm font-medium animate-bounce ${
          toast.type === 'success' ? 'bg-emerald-50 border-emerald-200 text-emerald-800' : 'bg-red-50 border-red-200 text-red-800'
        }`}>
          {toast.type === 'success' ? <Check className="w-4 h-4 text-emerald-600" /> : <ShieldAlert className="w-4 h-4 text-red-600" />}
          {toast.message}
        </div>
      )}

      {/* Header */}
      <header className="bg-white border-b border-gray-200 sticky top-0 z-10 font-sans font-sans">
        <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 font-sans">
          <div className="flex justify-between items-center h-16 font-sans">
            <div className="flex items-center gap-2">
              <div className="bg-indigo-600 p-2 rounded-lg font-sans">
                <Calendar className="w-6 h-6 text-white" />
              </div>
              <span className="text-xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-indigo-600 to-purple-600">
                ShiftMaster
              </span>
            </div>
            
            {/* User Profile */}
            <div className="flex items-center gap-4 font-sans">
              <div className="hidden md:flex flex-col items-end">
                <span className="text-sm font-bold text-gray-700 font-sans font-sans">หัวหน้า สมชาย</span>
                <span className="text-xs px-2 py-0.5 rounded-full bg-indigo-50 text-indigo-600 font-medium border border-indigo-100 font-sans font-sans">
                  ผู้ดูแลระบบ (Admin)
                </span>
              </div>
            </div>
          </div>
        </div>
      </header>

      {/* Navigation Tabs */}
      <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-6 font-sans">
        <nav className="flex space-x-2 border-b border-gray-200 overflow-x-auto pb-px">
          <button
            onClick={() => setActiveTab('calendar')}
            className={`px-4 py-2.5 text-sm font-medium rounded-t-lg border-b-2 whitespace-nowrap ${
              activeTab === 'calendar' 
                ? 'border-indigo-500 text-indigo-600 bg-indigo-50/50 font-semibold' 
                : 'border-transparent text-gray-500 hover:text-gray-700 hover:bg-gray-50'
            }`}
          >
            ดูตารางรวม
          </button>
          
          <button
            onClick={() => setActiveTab('employees')}
            className={`px-4 py-2.5 text-sm font-medium rounded-t-lg border-b-2 whitespace-nowrap ${
              activeTab === 'employees' 
                ? 'border-indigo-500 text-indigo-600 bg-indigo-50/50 font-semibold' 
                : 'border-transparent text-gray-500 hover:text-gray-700 hover:bg-gray-50 font-sans'
            }`}
          >
            รายชื่อพนักงาน
          </button>

          <button
            onClick={() => setActiveTab('shifttypes')}
            className={`px-4 py-2.5 text-sm font-medium rounded-t-lg border-b-2 whitespace-nowrap ${
              activeTab === 'shifttypes' 
                ? 'border-indigo-500 text-indigo-600 bg-indigo-50/50 font-semibold' 
                : 'border-transparent text-gray-500 hover:text-gray-700 hover:bg-gray-50 font-sans'
            }`}
          >
            ประเภทเวร ⚙️
          </button>

          <button
            onClick={() => setActiveTab('manage')}
            className={`px-4 py-2.5 text-sm font-medium rounded-t-lg border-b-2 whitespace-nowrap ${
              activeTab === 'manage' ? 'border-indigo-500 text-indigo-600 bg-indigo-50/50 font-semibold' : 'border-transparent text-gray-500 hover:text-gray-700 hover:bg-gray-50'
            }`}
          >
            จัดตารางเวร
          </button>

          <button
            onClick={() => setActiveTab('submit_leave')}
            className={`px-4 py-2.5 text-sm font-medium rounded-t-lg border-b-2 whitespace-nowrap ${
              activeTab === 'submit_leave' ? 'border-indigo-500 text-indigo-600 bg-indigo-50/50 font-semibold' : 'border-transparent text-gray-500 hover:text-gray-700 hover:bg-gray-50'
            }`}
          >
            พนักงานยื่นใบลา 📝
          </button>

          <button
            onClick={() => setActiveTab('leaves_review')}
            className={`px-4 py-2.5 text-sm font-medium rounded-t-lg border-b-2 whitespace-nowrap flex items-center gap-1.5 ${
              activeTab === 'leaves_review' ? 'border-indigo-500 text-indigo-600 bg-indigo-50/50 font-semibold' : 'border-transparent text-gray-500 hover:text-gray-700 hover:bg-gray-50'
            }`}
          >
            บันทึกผลการลา
            {leaves.length > 0 && (
              <span className="bg-indigo-600 text-white text-xs px-2 py-0.5 rounded-full font-bold">
                {leaves.length}
              </span>
            )}
          </button>
        </nav>

        {/* Content Area */}
        <main className="py-6">
          {activeTab === 'calendar' && <CalendarView />}
          {activeTab === 'employees' && <EmployeesListView />}
          {activeTab === 'shifttypes' && <ShiftTypesListView />}
          {activeTab === 'manage' && <ManageShiftsView />}
          {activeTab === 'submit_leave' && <EmployeeLeaveFormView />}
          {activeTab === 'leaves_review' && <LeavesReviewView />}
        </main>
      </div>
    </div>
  );
}
