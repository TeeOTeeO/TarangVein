  // --- ระบบ AI ช่วยจัดตารางเวรอัตโนมัติ (Heuristic Local Solver & Gemini API) ---

  const runLocalSmartScheduler = (startDateStr, daysCount) => {
    const generatedShifts = [];
    const shiftTracking = {};
    employees.forEach(emp => {
      shiftTracking[emp.id] = 0;
    });

    const start = new Date(startDateStr);
    
    for (let i = 0; i < daysCount; i++) {
      const targetDate = new Date(start);
      targetDate.setDate(start.getDate() + i);
      const dateString = targetDate.toISOString().split('T')[0];

      const assignedToday = new Set();

      // ขั้นตอนที่ 1: จัดกะเวรที่มีการระบุจำนวนตัวเลข (Fixed Quotas) ก่อน เพื่อความแน่นอน
      const fixedDemandShifts = shiftTypes.filter(st => st.requiredStaff !== 'everyone_else');
      const everyoneElseShifts = shiftTypes.filter(st => st.requiredStaff === 'everyone_else');

      fixedDemandShifts.forEach(st => {
        const quota = typeof st.requiredStaff === 'number' ? st.requiredStaff : 1;
        let assignedCount = 0;

        for (let q = 0; q < quota; q++) {
          const eligibleEmployees = employees.filter(emp => {
            const leave = getApprovedLeaveOnDate(emp.id, dateString);
            if (leave) {
              if (leave.type !== 'PERSONAL_MORNING' && leave.type !== 'PERSONAL_AFTERNOON') return false;
              if (st.id !== 'morning' && st.id !== 'chob' && st.id !== 'chobdor' && st.id !== 'smc' && st.id !== 'blood') return false;
            }

            if (assignedToday.has(emp.id)) return false;
            if ((st.id === 'night' || st.id === 'chobdor' || st.label.includes('ดึก') || st.label.includes('8.00-8.00') || st.label.includes('ชบด')) && emp.isPregnant) return false;

            return true;
          });

          if (eligibleEmployees.length > 0) {
            eligibleEmployees.sort((a, b) => shiftTracking[a.id] - shiftTracking[b.id]);
            const selectedEmp = eligibleEmployees[0];

            generatedShifts.push({
              id: `s_ai_${Date.now()}_${dateString}_${st.id}_${q}`,
              userId: selectedEmp.id,
              date: dateString,
              type: st.id
            });

            assignedToday.add(selectedEmp.id);
            shiftTracking[selectedEmp.id] += 1;
            assignedCount++;
          }
        }
      });

      // ขั้นตอนที่ 2: กวาดพนักงานทุกคนที่เหลืออยู่ (Everyone Else) เข้ากะเวรเช้า (หรือเวรที่ระบุเงื่อนไขนี้)
      everyoneElseShifts.forEach(st => {
        const remainingEmployees = employees.filter(emp => {
          const leave = getApprovedLeaveOnDate(emp.id, dateString);
          if (leave) {
            if (leave.type !== 'PERSONAL_MORNING' && leave.type !== 'PERSONAL_AFTERNOON') return false;
          }

          if (assignedToday.has(emp.id)) return false;

          return true;
        });

        remainingEmployees.forEach(selectedEmp => {
          generatedShifts.push({
            id: `s_ai_${Date.now()}_${dateString}_${st.id}_all`,
            userId: selectedEmp.id,
            date: dateString,
            type: st.id
          });

          assignedToday.add(selectedEmp.id);
          shiftTracking[selectedEmp.id] += 1;
        });
      });
    }

    return generatedShifts;
  };

  const handleAiAutoSchedule = async () => {
    if (employees.length === 0) {
      triggerToast('กรุณาเพิ่มพนักงานในระบบก่อนใช้ AI', 'error');
