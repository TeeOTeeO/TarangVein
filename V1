import React, { useState, useMemo } from 'react';
import { Calendar, Users, Clock, Plus, X, Check, UserCircle, Trash2, ShieldAlert, Heart, CalendarDays, AlertTriangle, FileSpreadsheet, ChevronLeft, ChevronRight, User } from 'lucide-react';

const SHIFT_TYPES = {
  MORNING: { id: 'morning', label: 'เวรเช้า (08:00 - 16:00)', color: 'bg-emerald-50 text-emerald-800 border-emerald-100', textSymbol: '🌅 เช้า' },
  AFTERNOON: { id: 'afternoon', label: 'เวรบ่าย (16:00 - 00:00)', color: 'bg-orange-50 text-orange-800 border-orange-100', textSymbol: '🌇 บ่าย' },
  NIGHT: { id: 'night', label: 'เวรดึก (00:00 - 08:00)', color: 'bg-blue-50 text-blue-800 border-blue-100', textSymbol: '🌃 ดึก' },
};

const LEAVE_TYPES = {
  PERSONAL_MORNING: { id: 'PERSONAL_MORNING', label: 'ลากิจครึ่งเช้า (8.00-12.00)', color: 'bg-amber-50 text-amber-850 border-amber-200' },
  PERSONAL_AFTERNOON: { id: 'PERSONAL_AFTERNOON', label: 'ลากิจครึ่งบ่าย (12.00-16.00)', color: 'bg-yellow-50 text-yellow-850 border-yellow-200' },
  PERSONAL_FULL: { id: 'PERSONAL_FULL', label: 'ลากิจเต็มวัน', color: 'bg-orange-50 text-orange-850 border-orange-200' },
  VACATION: { id: 'VACATION', label: 'ลาพักผ่อน', color: 'bg-indigo-50 text-indigo-850 border-indigo-200' },
  SICK: { id: 'SICK', label: 'ลาป่วย', color: 'bg-red-50 text-red-850 border-red-200' },
  MATERNITY: { id: 'MATERNITY', label: 'ลาคลอด', color: 'bg-pink-50 text-pink-850 border-pink-200' },
};

const MONTH_NAMES_TH = [
  'มกราคม', 'กุมภาพันธ์', 'มีนาคม', 'เมษายน', 'พฤษภาคม', 'มิถุนายน',
  'กรกฎาคม', 'สิงหาคม', 'กันยายน', 'ตุลาคม', 'พฤศจิกายน', 'ธันวาคม'
];

const WEEKDAYS_TH = ['อาทิตย์', 'จันทร์', 'อังคาร', 'พุธ', 'พฤหัสบดี', 'ศุกร์', 'เสาร์'];

export default function App() {
  // --- States ---
  const [activeTab, setActiveTab] = useState('calendar');
  
  // จัดเก็บเดือนและปีที่แสดงผลบนปฏิทินรายเดือน (ปี ค.ศ.)
  const [currentMonth, setCurrentMonth] = useState(new Date().getMonth());
  const [currentYear, setCurrentYear] = useState(new Date().getFullYear());

  // รายชื่อพนักงานเริ่มต้น พร้อมคำนำหน้าชื่อ
  const [employees, setEmployees] = useState([
    { id: '2', prefix: 'นางสาว', name: 'สมหญิง ยินดี', position: 'MT', age: 28, isPregnant: false },
    { id: '3', prefix: 'นาง', name: 'มานี มีใจ', position: 'ผู้ช่วย MT', age: 24, isPregnant: true },
    { id: '4', prefix: 'นาย', name: 'ปิติ รักดี', position: 'ผู้ช่วย MT', age: 30, isPregnant: false },
    { id: '5', prefix: 'นางสาว', name: 'กรรณิการ์ วงศ์ดี', position: 'MT (Part-time)', age: 22, isPregnant: false },
  ]);

  const [shifts, setShifts] = useState([
    { id: 's1', userId: '2', date: new Date().toISOString().split('T')[0], type: 'morning' },
    { id: 's2', userId: '3', date: new Date().toISOString().split('T')[0], type: 'afternoon' },
    { id: 's3', userId: '4', date: new Date().toISOString().split('T')[0], type: 'night' },
  ]);

  // ระบบเก็บข้อมูลการลาพักร้อน/ลางาน (ทดสอบจำลองให้ นาย ปิติ มีประวัติลาพักผ่อน 2 รายการ)
  const [leaves, setLeaves] = useState([
    { 
      id: 'l1', 
      userId: '4', 
      startDate: new Date().toISOString().split('T')[0], 
      endDate: new Date().toISOString().split('T')[0], 
      type: 'VACATION', 
      reason: 'ไปพักผ่อนต่างจังหวัดรอบที่ 1',
      status: 'approved' 
    },
    { 
      id: 'l2', 
      userId: '4', 
      startDate: new Date(Date.now() + 86400000 * 5).toISOString().split('T')[0], // อีก 5 วันถัดไป
      endDate: new Date(Date.now() + 86400000 * 5).toISOString().split('T')[0], 
      type: 'VACATION', 
      reason: 'ไปพักผ่อนต่างจังหวัดรอบที่ 2',
      status: 'approved' 
    },
    { 
      id: 'l3', 
      userId: '2', 
      startDate: new Date().toISOString().split('T')[0], 
      endDate: new Date().toISOString().split('T')[0], 
      type: 'SICK', 
      reason: 'เป็นไข้ตัวร้อน',
      status: 'approved' 
    }
  ]);

  // ระบบแจ้งเตือน (Custom Toast Notification)
  const [toast, setToast] = useState({ show: false, message: '', type: 'success' });

  // ฟอร์มสำหรับเพิ่มพนักงานใหม่
  const [newEmployee, setNewEmployee] = useState({
    prefix: 'นาย',
    name: '',
    position: 'MT',
    age: '',
    isPregnant: false
  });

  // ฟอร์มสำหรับจัดเวร
  const [newShift, setNewShift] = useState({
    userId: '2', 
    date: new Date().toISOString().split('T')[0],
    type: 'morning'
  });

  // ฟอร์มสำหรับพนักงานยื่นใบลา
  const [newLeave, setNewLeave] = useState({
    userId: '2',
    startDate: new Date().toISOString().split('T')[0],
    endDate: new Date().toISOString().split('T')[0],
    type: 'PERSONAL_MORNING',
    reason: ''
  });

  // --- ฟังก์ชันแสดงข้อความแจ้งเตือน ---
  const triggerToast = (message, type = 'success') => {
    setToast({ show: true, message, type });
    setTimeout(() => {
      setToast({ show: false, message: '', type: 'success' });
    }, 3000);
  };

  // --- คำนวณวันในเดือนสำหรับสร้างปฏิทินรายเดือน ---
  const calendarDays = useMemo(() => {
    const firstDayIndex = new Date(currentYear, currentMonth, 1).getDay(); // วันแรกของเดือนเป็นวันอะไร (0-6)
    const totalDays = new Date(currentYear, currentMonth + 1, 0).getDate(); // จำนวนวันทั้งหมดในเดือนนี้
    const prevTotalDays = new Date(currentYear, currentMonth, 0).getDate(); // จำนวนวันทั้งหมดในเดือนก่อนหน้า

    const days = [];

    // ดึงวันของเดือนก่อนหน้ามาใส่ให้เต็มสัปดาห์แรก (Padding)
    for (let i = firstDayIndex - 1; i >= 0; i--) {
      const dayNum = prevTotalDays - i;
      const prevMonth = currentMonth === 0 ? 11 : currentMonth - 1;
      const prevYear = currentMonth === 0 ? currentYear - 1 : currentYear;
      const dateString = `${prevYear}-${String(prevMonth + 1).padStart(2, '0')}-${String(dayNum).padStart(2, '0')}`;
      days.push({
        dateString,
        dayNum,
        isCurrentMonth: false,
      });
    }

    // ดึงวันของเดือนปัจจุบัน
    for (let i = 1; i <= totalDays; i++) {
      const dateString = `${currentYear}-${String(currentMonth + 1).padStart(2, '0')}-${String(i).padStart(2, '0')}`;
      days.push({
        dateString,
        dayNum: i,
        isCurrentMonth: true,
      });
    }

    // ดึงวันของเดือนถัดไปมาใส่ให้เต็มปฏิทิน (ให้ครบแถวละ 7 วัน ทั้งหมด 42 ช่อง)
    const remainingSlots = 42 - days.length;
    for (let i = 1; i <= remainingSlots; i++) {
      const nextMonth = currentMonth === 11 ? 0 : currentMonth + 1;
      const nextYear = currentMonth === 11 ? currentYear + 1 : currentYear;
      const dateString = `${nextYear}-${String(nextMonth + 1).padStart(2, '0')}-${String(i).padStart(2, '0')}`;
      days.push({
        dateString,
        dayNum: i,
        isCurrentMonth: false,
      });
    }

    return days;
  }, [currentMonth, currentYear]);

  const handlePrevMonth = () => {
    if (currentMonth === 0) {
      setCurrentMonth(11);
      setCurrentYear(currentYear - 1);
    } else {
      setCurrentMonth(currentMonth - 1);
    }
  };

  const handleNextMonth = () => {
    if (currentMonth === 11) {
      setCurrentMonth(0);
      setCurrentYear(currentYear + 1);
    } else {
      setCurrentMonth(currentMonth + 1);
    }
  };

  const getUserById = (id) => employees.find(u => u.id === id);

  // ตรวจสอบว่าพนักงานลางานในวันที่กำหนดหรือไม่
  const getApprovedLeaveOnDate = (userId, dateStr) => {
    const targetDate = new Date(dateStr);
    targetDate.setHours(0,0,0,0);

    return leaves.find(l => {
      if (l.userId !== userId || l.status !== 'approved') return false;
      const start = new Date(l.startDate);
      const end = new Date(l.endDate);
      start.setHours(0,0,0,0);
      end.setHours(0,0,0,0);
      return targetDate >= start && targetDate <= end;
    });
  };

  // --- ฟังก์ชันจัดการข้อมูล (Actions) ---
  
  // เพิ่มพนักงานใหม่
  const handleAddEmployee = (e) => {
    e.preventDefault();
    if (!newEmployee.name.trim() || !newEmployee.age) {
      triggerToast('กรุณากรอกข้อมูลพนักงานให้ครบถ้วน', 'error');
      return;
    }

    const canBePregnant = newEmployee.prefix === 'นาง' || newEmployee.prefix === 'นางสาว';

    const createdEmployee = {
      id: `emp_${Date.now()}`,
      prefix: newEmployee.prefix,
      name: newEmployee.name,
      position: newEmployee.position,
      age: parseInt(newEmployee.age),
      isPregnant: canBePregnant ? newEmployee.isPregnant : false
    };

    setEmployees([...employees, createdEmployee]);
    setNewEmployee({ prefix: 'นาย', name: '', position: 'MT', age: '', isPregnant: false });
    triggerToast('เพิ่มข้อมูลพนักงานเรียบร้อยแล้ว');
  };

  // ลบพนักงาน
  const handleDeleteEmployee = (id) => {
    setShifts(shifts.filter(s => s.userId !== id));
    setLeaves(leaves.filter(l => l.userId !== id));
    setEmployees(employees.filter(e => e.id !== id));
    triggerToast('ลบข้อมูลพนักงานเรียบร้อยแล้ว', 'error');
  };

  // เพิ่มเวร
  const handleAddShift = (e) => {
    e.preventDefault();
    const selectedUser = getUserById(newShift.userId);
    if (!selectedUser) {
      triggerToast('กรุณาเลือกพนักงานก่อนจัดเวร', 'error');
      return;
    }

    // ตรวจสอบเงื่อนไขว่าวันดังกล่าวพนักงานลาอยู่หรือไม่
    const onLeave = getApprovedLeaveOnDate(newShift.userId, newShift.date);
    if (onLeave) {
      const leaveInfo = LEAVE_TYPES[onLeave.type] || { label: 'ลางาน' };
      triggerToast(`ไม่สามารถจัดเวรได้เนื่องจากพนักงานลงทะเบียนลางานในวันดังกล่าว (${leaveInfo.label})`, 'error');
      return;
    }

    // ตรวจสอบว่าในกะวันเดียวกันและกะประเภทเดียวกัน ลงพนักงานคนเดิมซ้ำไปแล้วหรือยัง
    const isDuplicate = shifts.some(s => s.userId === newShift.userId && s.date === newShift.date && s.type === newShift.type);
    if (isDuplicate) {
      triggerToast('พนักงานท่านนี้ลงกะเวรดังกล่าวในวันนี้ไปแล้ว', 'error');
      return;
    }

    const newShiftData = {
      id: `s_${Date.now()}`,
      ...newShift
    };
    setShifts([...shifts, newShiftData]);
    triggerToast('จัดตารางเวรให้พนักงานสำเร็จแล้ว');
  };

  // บันทึกการลาโดยตรง (พนักงานหรือแอดมินคีย์)
  const handleAddLeaveRequest = (e) => {
    e.preventDefault();
    if (new Date(newLeave.startDate) > new Date(newLeave.endDate)) {
      triggerToast('วันที่เริ่มต้นลา ต้องไม่มากกว่าวันที่สิ้นสุดลา', 'error');
      return;
    }

    const newRequest = {
      id: `leave_${Date.now()}`,
      ...newLeave,
      status: 'approved' // บันทึกและอนุมัติทันทีโดยไม่ต้องรอตรวจรับคำขอ
    };

    setLeaves([...leaves, newRequest]);
    setNewLeave({
      userId: employees[0]?.id || '',
      startDate: new Date().toISOString().split('T')[0],
      endDate: new Date().toISOString().split('T')[0],
      type: 'PERSONAL_MORNING',
      reason: ''
    });
    triggerToast('บันทึกประวัติการลาเรียบร้อยแล้ว');
  };

  // ลบประวัติการลา
  const handleDeleteLeave = (leaveId) => {
    setLeaves(leaves.filter(l => l.id !== leaveId));
    triggerToast('ลบประวัติการลาเรียบร้อยแล้ว', 'error');
  };

  // ลบกะเวรรายวัน
  const handleDeleteShift = (shiftId) => {
    setShifts(shifts.filter(s => s.id !== shiftId));
    triggerToast('ลบตารางเวรเรียบร้อยแล้ว');
  };

  // --- คำนวณการจัดกลุ่มการลาแยกรายบุคคล (Grouped by Employee) ---
  const groupedLeaves = useMemo(() => {
    const groups = {};

    // จัดกลุ่มตามพนักงาน
    leaves.forEach(leave => {
      if (!groups[leave.userId]) {
        groups[leave.userId] = {
          userId: leave.userId,
          employee: getUserById(leave.userId),
          items: [],
          stats: {} // นับจำนวนครั้งแยกตามประเภทการลา
        };
      }
      
      groups[leave.userId].items.push(leave);
      
      const leaveTypeLabel = LEAVE_TYPES[leave.type]?.label || 'อื่น ๆ';
      groups[leave.userId].stats[leaveTypeLabel] = (groups[leave.userId].stats[leaveTypeLabel] || 0) + 1;
    });

    // เรียงประวัติการลาของแต่ละคนจากใหม่ไปเก่า
    Object.values(groups).forEach(group => {
      group.items.sort((a, b) => new Date(b.startDate) - new Date(a.startDate));
    });

    return Object.values(groups);
  }, [leaves, employees]);

  // --- Components ย่อย ---
  
  // 1. หน้าตารางเวรรวม (Calendar View) - รูปแบบรายเดือนเต็มจอตามรูปตัวอย่าง
  const CalendarView = () => {
    return (
      <div className="space-y-4">
        {/* ส่วนหัวแสดงการเปลี่ยนเดือน */}
        <div className="flex flex-col sm:flex-row justify-between items-center bg-white p-4 rounded-xl shadow-sm border border-gray-100 gap-4">
          <h2 className="text-xl font-bold text-gray-800 flex items-center gap-2">
            <Calendar className="w-6 h-6 text-indigo-600" /> ตารางเวรและสรุปกะรายวัน
          </h2>
          <div className="flex items-center gap-4 bg-slate-100 rounded-lg p-1.5">
            <button 
              onClick={handlePrevMonth} 
              className="p-1.5 hover:bg-white rounded-md transition-all text-gray-600 hover:text-indigo-600"
              title="เดือนก่อนหน้า"
            >
              <ChevronLeft className="w-5 h-5" />
            </button>
            <span className="font-bold text-gray-700 min-w-[120px] text-center text-sm md:text-base">
              {MONTH_NAMES_TH[currentMonth]} {currentYear + 543}
            </span>
            <button 
              onClick={handleNextMonth} 
              className="p-1.5 hover:bg-white rounded-md transition-all text-gray-600 hover:text-indigo-600"
              title="เดือนถัดไป"
            >
              <ChevronRight className="w-5 h-5" />
            </button>
          </div>
        </div>

        {/* ตารางแสดงผลรายเดือน */}
        <div className="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
          {/* ส่วนหัวชื่อวัน (อาทิตย์ - เสาร์) */}
          <div className="grid grid-cols-7 border-b border-gray-200 bg-slate-50">
            {WEEKDAYS_TH.map((day, idx) => (
              <div 
                key={day} 
                className={`py-3 text-center text-xs md:text-sm font-bold border-r border-gray-200 last:border-r-0 ${
                  idx === 0 ? 'text-red-600 bg-red-50/20' : idx === 6 ? 'text-blue-600 bg-blue-50/20' : 'text-gray-700'
                }`}
              >
                {day}
              </div>
            ))}
          </div>

          {/* ตารางวันที่ 6 แถว แถวละ 7 วัน */}
          <div className="grid grid-cols-7 grid-rows-6 divide-x divide-y divide-gray-200">
            {calendarDays.map((day, idx) => {
              const dayShifts = shifts.filter(s => s.date === day.dateString);
              
              // ค้นหาพนักงานที่บันทึกการลาในวันนี้
              const dayLeaves = leaves.filter(l => {
                if (l.status !== 'approved') return false;
                const targetDate = new Date(day.dateString);
                const start = new Date(l.startDate);
                const end = new Date(l.endDate);
                targetDate.setHours(0,0,0,0);
                start.setHours(0,0,0,0);
                end.setHours(0,0,0,0);
                return targetDate >= start && targetDate <= end;
              });

              // ตรวจสอบว่าเป็นวันปัจจุบันหรือไม่
              const isToday = day.dateString === new Date().toISOString().split('T')[0];

              return (
                <div 
                  key={day.dateString + '-' + idx} 
                  className={`min-h-[140px] md:min-h-[160px] p-2 flex flex-col justify-between hover:bg-slate-50/50 transition-colors ${
                    day.isCurrentMonth ? 'bg-white' : 'bg-slate-50 text-gray-400'
                  } ${isToday ? 'ring-2 ring-indigo-500 ring-inset bg-indigo-50/10' : ''}`}
                >
                  {/* หัวช่องระบุเลขวัน */}
                  <div className="flex justify-between items-center">
                    <span className={`text-xs md:text-sm font-bold px-1.5 py-0.5 rounded-full ${
                      isToday 
                        ? 'bg-indigo-600 text-white' 
                        : day.isCurrentMonth 
                        ? 'text-gray-800' 
                        : 'text-gray-400'
                    }`}>
                      {day.dayNum}
                    </span>
                    
                    {/* ปุ่มด่วนสำหรับแอดมินคลิกไปจัดตารางของวันนี้ */}
                    <button
                      onClick={() => {
                        setNewShift(prev => ({ ...prev, date: day.dateString }));
                        setActiveTab('manage');
                      }}
                      className="text-[10px] text-indigo-600 hover:text-indigo-800 font-semibold opacity-0 hover:opacity-100 focus:opacity-100 transition-opacity flex items-center gap-0.5"
                      title="จัดตารางเวรในวันนี้"
                    >
                      <Plus className="w-3 h-3" /> ลงเวร
                    </button>
                  </div>

                  {/* สรุปรายละเอียดเวรรายวัน */}
                  <div className="mt-1 flex-1 space-y-1.5 overflow-y-auto max-h-[100px] scrollbar-thin">
                    {/* แยกกลุ่มเวร เช้า, บ่าย, ดึก */}
                    {Object.values(SHIFT_TYPES).map(st => {
                      const shiftsInGroup = dayShifts.filter(s => s.type === st.id);
                      if (shiftsInGroup.length === 0) return null;

                      return (
                        <div key={st.id} className="text-[10px] leading-tight">
                          <div className="font-semibold text-gray-500 text-[9px] flex items-center gap-1">
                            <span>{st.textSymbol}</span>
                          </div>
                          <div className="pl-1 space-y-0.5">
                            {shiftsInGroup.map(s => {
                              const user = getUserById(s.userId);
                              if (!user) return null;
                              return (
                                <div key={s.id} className="flex justify-between items-center group/item text-gray-700 bg-slate-100/60 p-0.5 px-1 rounded hover:bg-slate-200/50">
                                  <span className="truncate max-w-[80%] font-medium">
                                    {user.prefix}{user.name.split(' ')[0]}
                                  </span>
                                  {/* ปุ่มลบกะออกแบบลัด */}
                                  <button 
                                    onClick={(e) => {
                                      e.stopPropagation();
                                      handleDeleteShift(s.id);
                                    }}
                                    className="opacity-0 group-hover/item:opacity-100 text-red-500 hover:text-red-700 transition-opacity p-0.5"
                                    title="ลบเวรนี้"
                                  >
                                    <X className="w-2.5 h-2.5" />
                                  </button>
                                </div>
                              );
                            })}
                          </div>
                        </div>
                      );
                    })}

                    {dayShifts.length === 0 && dayLeaves.length === 0 && (
                      <div className="h-full flex items-center justify-center text-[10px] text-gray-300 py-3">
                        ว่าง
                      </div>
                    )}
                  </div>

